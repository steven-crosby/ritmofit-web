# RitmoFit API — local secrets for `wrangler dev`.
# Copy to `apps/api/.dev.vars` (git-ignored) and fill in. NEVER commit real values.

# --- Better Auth (M1) ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8787

# Sign in with Apple (authentication only — NOT Apple Music). Keep strictly
# separate from the Apple Music keys below.
APPLE_SIGNIN_CLIENT_ID=
APPLE_SIGNIN_TEAM_ID=
APPLE_SIGNIN_KEY_ID=
APPLE_SIGNIN_PRIVATE_KEY=

# Google sign-in (M1)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Declared now, first used in M2 to encrypt provider tokens at rest.
ENCRYPTION_KEY=

# --- M2 placeholders (document now, UNUSED in M1 — do not wire up yet) ---
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SOUNDCLOUD_CLIENT_ID=
# SOUNDCLOUD_CLIENT_SECRET=
# APPLE_MUSIC_KEY_ID=
# APPLE_MUSIC_TEAM_ID=
# APPLE_MUSIC_PRIVATE_KEY=
