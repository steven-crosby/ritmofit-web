{
  "name": "@ritmofit/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply ritmofit --local",
    "db:seed:local": "wrangler d1 execute ritmofit --local --file=./src/db/seed.sql"
  },
  "dependencies": {
    "@ritmofit/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.3",
    "wrangler": "^4.0.0"
  }
}
