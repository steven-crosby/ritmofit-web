# Copy to `.dev.vars` (git-ignored) for local `wrangler dev`. Prod uses `wrangler secret put`.

# Better Auth — required to boot. Generate a strong secret:  openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL of the API Worker, no trailing slash.
BETTER_AUTH_URL=http://localhost:8787
# Optional locally. Production HTTPS fails closed without this comma-separated
# invite allowlist; store it with `wrangler secret put BETA_ALLOWED_EMAILS`.
BETA_ALLOWED_EMAILS=
# Web SPA origin allowed by CORS (defaults to http://localhost:5173 when unset).
WEB_ORIGIN=http://localhost:5173

# Optional social sign-in. Apple activates when APPLE_CLIENT_ID plus either a
# static APPLE_CLIENT_SECRET or the Team/Key/private-key fields are set. Apple
# SIGN-IN only; unrelated to Apple Music (that's M2, different credentials).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
# Static, pre-generated Apple client-secret JWT fallback. Prefer the dynamic
# fields below so the Worker signs fresh JWTs from the .p8 key.
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# PEM text may use escaped newlines when set as a Worker secret.
APPLE_PRIVATE_KEY=

# Declared now, used in M2 to encrypt provider tokens (conventions.md). Unused in M1.
ENCRYPTION_KEY=

# SoundCloud API app credentials (M2). Both halves required to enable the live
# provider; server-side only (SoundCloud treats all clients as confidential).
# Leave blank to run provider search/import/connect against the mock seam below.
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
# OAuth connect redirect URI; must be registered with SoundCloud. Defaults to
# ${BETTER_AUTH_URL}/api/v1/providers/soundcloud/callback when unset.
SOUNDCLOUD_REDIRECT_URI=http://localhost:8787/api/v1/providers/soundcloud/callback

# Spotify app credentials (M2). Both halves required to enable live search/lookup
# (client-credentials, server-side). NEVER used for BPM — audio-features is
# deprecated for new apps (music-providers.md). Blank → mock seam.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Apple Music developer token config + optional storefront. Prefer the dynamic
# Team/Key/private-key fields so the Worker signs fresh developer tokens from
# the .p8 key. The static APPLE_MUSIC_DEVELOPER_TOKEN is kept as a fallback.
# Distinct from Sign in with Apple. Blank → mock seam.
APPLE_MUSIC_DEVELOPER_TOKEN=
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=
APPLE_MUSIC_STOREFRONT=us

# Third-party BPM provider (GetSongBPM) to fill tracks.display_bpm (M2, optional).
# NEVER Spotify (audio-features deprecated). Blank → mock seam (deterministic BPM).
GETSONGBPM_API_KEY=

# Dev: serve provider search/import from the mock catalog (and expose the /mock/*
# seam) so the builder works with zero provider keys. Leave unset/false in production.
MOCK_PROVIDERS=true

# Transactional email (password reset + verification, B1/B2) via Resend. Blank →
# emails are logged to the Worker console instead of sent (dev fallback), so reset/
# verify links are clickable from `wrangler dev` logs. NEVER leave blank in prod.
RESEND_API_KEY=
# From address; must be on a Resend-verified domain. Defaults to noreply@ritmofit.studio.
EMAIL_FROM=RitmoFit <noreply@ritmofit.studio>
