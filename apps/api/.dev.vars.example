# Copy to `.dev.vars` (git-ignored) for local `wrangler dev`. Prod uses `wrangler secret put`.

# Better Auth — required to boot. Generate a strong secret:  openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL of the API Worker, no trailing slash.
BETTER_AUTH_URL=http://localhost:8787
# Web SPA origin allowed by CORS (defaults to http://localhost:5173 when unset).
WEB_ORIGIN=http://localhost:5173

# Optional social sign-in — a provider activates only when BOTH halves are set.
# Apple SIGN-IN only; unrelated to Apple Music (that's M2, different credentials).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Declared now, used in M2 to encrypt provider tokens (conventions.md). Unused in M1.
ENCRYPTION_KEY=

# SoundCloud API app credentials (M2). Both halves required to enable the live
# provider; server-side only (SoundCloud treats all clients as confidential).
# Leave blank to run provider search/import/connect against the mock seam below.
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
# OAuth connect redirect URI; must be registered with SoundCloud. Defaults to
# ${BETTER_AUTH_URL}/api/v1/providers/soundcloud/callback when unset.
SOUNDCLOUD_REDIRECT_URI=http://localhost:8787/api/v1/providers/soundcloud/callback

# Spotify app credentials (M2). Both halves required to enable live search/lookup
# (client-credentials, server-side). NEVER used for BPM — audio-features is
# deprecated for new apps (music-providers.md). Blank → mock seam.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Apple Music developer token (ES256 JWT signed from the .p8 key, out of band) +
# optional storefront. Distinct from Sign in with Apple. Blank → mock seam.
APPLE_MUSIC_DEVELOPER_TOKEN=
APPLE_MUSIC_STOREFRONT=us

# Dev: serve provider search/import from the mock catalog (and expose the /mock/*
# seam) so the builder works with zero provider keys. Leave unset/false in production.
MOCK_PROVIDERS=true
