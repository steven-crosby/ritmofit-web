# Browser security headers for the SPA + static assets, served by Cloudflare
# Workers static assets (the Worker does not run for these paths — see
# wrangler.toml `run_worker_first = ["/api/*"]`). The API/health responses set the
# same transport/frame headers in apps/api/src/index.ts; keep the two in sync.
#
# CSP notes:
#   script-src  'self' + Cloudflare insights beacon (Vite emits hashed same-origin
#               ES modules; no inline scripts).
#   style-src   'unsafe-inline' is required for the app's inline style attributes
#               (e.g. the live-mode beat/intensity custom properties) and Vite's
#               injected styles.
#   font-src    'self' — the three OFL faces are self-hosted under /fonts (no CDN).
#   img-src     https: + data: for provider album artwork from arbitrary CDNs.
#   connect-src 'self' (same-origin /api) + the insights beacon endpoint + Apple
#               Music API hosts (*.music.apple.com / *.mzstatic.com) that MusicKit
#               JS calls once a user connects their Apple Music account, plus
#               *.itunes.apple.com — MusicKit web playback fetches the streaming
#               handshake + license from play.itunes.apple.com/WebObjects/MZPlay.woa
#               and the HLS audio manifest/segments from aod-ssl.itunes.apple.com
#               (Apple serves audio from several *.itunes.apple.com hosts; without
#               them playback fails with "Failed to fetch" / "Could not fetch
#               manifest" — both blocks observed live during verification).
#   media-src   'self' blob: — MusicKit plays via Media Source Extensions, so the
#               <audio> element's source is a blob: MediaSource URL (segment bytes
#               themselves are fetched over connect-src). Without this, default-src
#               'self' governs media and blocks the blob source.
#   script-src  also allows js-cdn.music.apple.com (the MusicKit JS library, loaded
#               on demand only when a user starts the Apple Music connect flow),
#               w.soundcloud.com (the official SoundCloud Widget API, loaded only
#               when SoundCloud playback starts), and sdk.scdn.co (the Spotify Web
#               Playback SDK, loaded only when Spotify playback starts).
#   connect-src also allows api.spotify.com / *.spotify.com (+ wss for the SDK's
#               realtime player connection) and *.scdn.co that the Web Playback SDK
#               and the Connect Web API (start/seek/pause) call once playback starts.
#   frame-src   allows the Apple Music / Apple ID authorization surfaces MusicKit
#               opens for consent, the SoundCloud Widget player iframe, and the
#               Spotify Web Playback SDK's hidden player iframe (sdk.scdn.co).
#   Permissions-Policy delegates encrypted-media to sdk.scdn.co — the Spotify SDK
#               plays DRM (Widevine) in its cross-origin iframe.
#               NOTE: the Spotify host/permission set (wss, *.scdn.co,
#               encrypted-media) still needs the same live-tuning pass Apple/
#               SoundCloud got — confirm against securitypolicyviolation + the SDK
#               error events during the first real Spotify playback pass.
#   Cache-Control includes `no-transform` so Cloudflare JavaScript Detections do
#   not inject a CSP-blocked inline challenge script into the SPA HTML.
/*
  Cache-Control: public, max-age=0, must-revalidate, no-transform
  Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com https://js-cdn.music.apple.com https://w.soundcloud.com https://sdk.scdn.co; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https:; media-src 'self' blob:; connect-src 'self' https://static.cloudflareinsights.com https://*.music.apple.com https://*.mzstatic.com https://*.itunes.apple.com https://api.spotify.com https://*.spotify.com wss://*.spotify.com https://*.scdn.co; frame-src https://authorize.music.apple.com https://idmsa.apple.com https://w.soundcloud.com https://sdk.scdn.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), encrypted-media=(self "https://sdk.scdn.co")

# Self-hosted fonts change rarely and are safe to cache hard. (Filenames are not
# content-hashed; bump by renaming the file + fonts.css if a face is ever updated.)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
