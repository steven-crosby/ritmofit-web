# Browser security headers for the SPA + static assets, served by Cloudflare
# Workers static assets (the Worker does not run for these paths — see
# wrangler.toml `run_worker_first = ["/api/*"]`). The API/health responses set the
# same transport/frame headers in apps/api/src/index.ts; keep the two in sync.
#
# CSP notes:
#   script-src  'self' + Cloudflare insights beacon (Vite emits hashed same-origin
#               ES modules; no inline scripts).
#   style-src   'unsafe-inline' is required for the app's inline style attributes
#               (e.g. the live-mode beat/intensity custom properties) and Vite's
#               injected styles.
#   font-src    'self' — the three OFL faces are self-hosted under /fonts (no CDN).
#   img-src     https: + data: for provider album artwork from arbitrary CDNs.
#   connect-src 'self' (same-origin /api) + the insights beacon endpoint + Apple
#               Music API hosts (api.music.apple.com / *.mzstatic.com) that MusicKit
#               JS calls once a user connects their Apple Music account.
#   script-src  also allows js-cdn.music.apple.com (the MusicKit JS library, loaded
#               on demand only when a user starts the Apple Music connect flow)
#               and w.soundcloud.com (the official SoundCloud Widget API, loaded
#               only when SoundCloud playback starts).
#   frame-src   allows the Apple Music / Apple ID authorization surfaces MusicKit
#               opens for consent plus the SoundCloud Widget player iframe.
#               NOTE: tune against CSP violation reports during the first real
#               provider playback/connect pass.
#   Cache-Control includes `no-transform` so Cloudflare JavaScript Detections do
#   not inject a CSP-blocked inline challenge script into the SPA HTML.
/*
  Cache-Control: public, max-age=0, must-revalidate, no-transform
  Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com https://js-cdn.music.apple.com https://w.soundcloud.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https:; connect-src 'self' https://static.cloudflareinsights.com https://*.music.apple.com https://*.mzstatic.com; frame-src https://authorize.music.apple.com https://idmsa.apple.com https://w.soundcloud.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()

# Self-hosted fonts change rarely and are safe to cache hard. (Filenames are not
# content-hashed; bump by renaming the file + fonts.css if a face is ever updated.)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
